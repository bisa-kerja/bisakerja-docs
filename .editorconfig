root = true

[*]
indent_size = 2
tab_width = 2
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true
end_of_line = lf

[*.{js,jsx,ts,tsx,css,scss}]
indent_style = tab
indent_size = 2
tab_width = 2

[*.{json,yml,yaml,md,mdx}]
indent_style = space
indent_size = 2

[*.{md,mdx}]
trim_trailing_whitespace = false
